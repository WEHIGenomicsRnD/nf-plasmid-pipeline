nextflow_process {

    name "Test Unzip files"
    script "../main.nf"
    process "UnzipFiles"

    test("Plasmid - result") {

        when {
            process {
                """
                input[0] = Channel.of(file(params.pipelines_testdata_base_path + '/Batchtest.zip', checkIfExists: true))
                input[1] = Channel.of(params.pipelines_testdata_base_path)
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("Plasmid - result - stub") {

    options "-stub"

        when {
            process {
                """
                input[0] = Channel.of(file(params.pipelines_testdata_base_path + '/Batchtest.zip', checkIfExists: true))
                input[1] = Channel.of(params.pipelines_testdata_base_path)
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
