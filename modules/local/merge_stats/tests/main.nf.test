nextflow_process {

    name "Test Merge Stats"
    script "../main.nf"
    process "MergeQCStats"

    test("Plasmid - result") {

        when {
            process {
                """
                input[0] = Channel.of("20260212_Plasmid_Batch12")
                input[1] = Channel.of([params.pipelines_testdata_base_path + "/launchclonepipe/20260212_test.g-1-sample_QC.txt",
                                       params.pipelines_testdata_base_path + "/launchclonepipe/20260212_test.g-2-sample_QC.txt",
                                       params.pipelines_testdata_base_path + "/launchclonepipe/20260212_test.g-3-sample_QC.txt"
                                      ])
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out.versions).match() }
            )
        }
    }

    test("Plasmid - result - stub") {

    options "-stub"

        when {
            process {
                """
                input[0] = Channel.of("20260212_Plasmid_Batch12")
                input[1] = Channel.of([params.pipelines_testdata_base_path + "launchclonepipe/20260212_test.g-1-sample_QC.txt",
                                       params.pipelines_testdata_base_path + "/launchclonepipe/20260212_test.g-2-sample_QC.txt",
                                       params.pipelines_testdata_base_path + "/launchclonepipe/20260212_test.g-3-sample_QC.txt"
                                     ])
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out.versions).match() }
            )
        }
    }
}
