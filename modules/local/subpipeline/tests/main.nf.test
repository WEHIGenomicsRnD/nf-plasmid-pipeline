nextflow_process {

    name "Test LaunchClonePipe"
    script "../main.nf"
    process "LaunchClonePipe"

    test("Plasmid - result-1") { 


        when {
            process {
                """
                input[0] = Channel.of([
                     params.pipelines_testdata_base_path + '/20260212_test.g_v1.8.0/',
                     params.pipelines_testdata_base_path + '/createsamplesheet/20260212_test.g.csv',
                     1,
                     params.pipelines_testdata_base_path + '/extracted_tar/test/gdj634/'
                      ])
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out.versions).match() }
            )
        }
    }


    test("Plasmid - result-2") {


        when {
            process {
                """
                input[0] = Channel.of([
                     params.pipelines_testdata_base_path + '/20260212_test.g_v1.8.0/',
                     params.pipelines_testdata_base_path + '/createsamplesheet/20260212_test.g.csv',
                     2,
                     params.pipelines_testdata_base_path + '/extracted_tar/test/gdj634/'
                      ])
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out.versions).match() }
            )
        }
    }

    test("Plasmid - result-3") {


        when {
            process {
                """
                input[0] = Channel.of([
                     params.pipelines_testdata_base_path + '/20260212_test.g_v1.8.0/',
                     params.pipelines_testdata_base_path + '/createsamplesheet/20260212_test.g.csv',
                     3,
                     params.pipelines_testdata_base_path + '/extracted_tar/test/gdj634/'
                      ])
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out.versions).match() }
            )
        }
    }

    test("Plasmid - result - stub") {

    options "-stub"

        when {
            process {
                """
                input[0] = Channel.of([
                     params.pipelines_testdata_base_path + '/20260212_test.g/',
                     params.pipelines_testdata_base_path + '/createsamplesheet/20260212_test.g.csv',
                     1,
                     params.pipelines_testdata_base_path + '/extracted_tar/test/gdj634/'
                     ])
                """

            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out.versions).match() }
            )
        }
    }
}
