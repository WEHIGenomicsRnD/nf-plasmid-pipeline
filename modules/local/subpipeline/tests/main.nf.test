nextflow_process {

    name "Test LaunchClonePipe"
    script "../main.nf"
    process "LaunchClonePipe"

    test("Plasmid - result") {

        when {
            process {
                """
                input[0] = file(params.modules_testdata_base_path + "genomics/sarscov2/genome/genome.gtf", checkIfExists: true)
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("Plasmid - result - stub") {

    options "-stub"

        when {
            process {
                """
                input[0] = file(params.modules_testdata_base_path + "genomics/sarscov2/genome/genome.gtf", checkIfExists: true)
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
