nextflow_process {

    name "Test UnpackFastq"
    script "../main.nf"
    process "UnpackFastq"

    test("Plasmid - result") {

        when {
            process {
                """
                input[0] = Channel.of(params.pipelines_testdata_base_path)
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out) }
            )
        }
    }

    test("Plasmid - result - stub") {

    options "-stub"

        when {
            process {
                """
                input[0] = Channel.of(params.pipelines_testdata_base_path)
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out) }
            )
        }
    }
}
