nextflow_process {

    name "Test HandOver"
    script "../main.nf"
    process "HandOver"

    test("Plasmid - result") {
        when {
            process {
                """
                input[0] = Channel.of(["test.g", result1, Batch12, 20260212 ])
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out.versions).match() }
            )
        }
    }

    test("Plasmid - result - stub") {

    options "-stub"

        when {
            process {
                """
                input[0] = input[0] = Channel.of(["test.g", result1, Batch12, 20260212 ])
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out.versions).match() }
            )
        }
    }
}
