nextflow_process {

    name "Test Process CreateSampleSheet"
    script "../main.nf"
    process "CreateSampleSheet"

    test("CreateSampleSheet") {

        when {
            process {
                """
                input[0] = Channel.of(params.pipelines_testdata_base_path + "/ref")
                input[1] = Channel.of(params.pipelines_testdata_base_path)
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert process.out.csv_ch[0].contains(".csv") },
                { assert process.out.plasmidtxt_ch[0].contains(".txt") }
            )
        }
    }

    test("CreateSampleSheet - stub") {

    options "-stub"

        when {
            process {
                """
                input[0] = Channel.of(params.pipelines_testdata_base_path + "/ref", checkIfExists: true)
                input[1] = Channel.of(params.pipelines_testdata_base_path)
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert process.out.csv_ch[0].contains(".csv") },
                { assert process.out.plasmidtxt_ch[0].contains(".txt") }
            )
        }
    }
}
