nextflow_process {

    name "Test SendEmail"
    script "../main.nf"
    process "SendEmail"

    test("Plasmid - result") {

        when {
            process {
                """
                input[0] = Channel.of(file(params.pipelines_testdata_base_path + '/createsamplesheet/20260212_Plasmid_Batch12.txt', checkIfExists: true))
                input[1] = params.pipelines_testdata_base_path
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("Plasmid - result - stub") {

    options "-stub"

        when {
            process {
                """
                input[0] = Channel.of(file(params.pipelines_testdata_base_path + '/createsamplesheet/20260212_Plasmid_Batch12.txt', checkIfExists: true))
                input[1] = params.pipelines_testdata_base_path
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
